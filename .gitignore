node_modules

# Secrets. `.env` and `.env.local` alone did NOT cover the shapes people
# actually create — a backup taken before switching a connection string
# (.env.atlas.backup, .env.bak, .env.prod) was fully committable, which is
# exactly the file most likely to hold live production credentials.
# Ignore every .env variant, then re-admit the one template that IS tracked.
.env
.env.*
!.env.example

dist
build
*.log
.DS_Store
coverage

# npm workspaces use a single root lockfile; nested per-app locks are stray
# artifacts from running `npm install` inside a workspace and must not be tracked.
apps/*/package-lock.json

# Playwright e2e output
/e2e/test-results/
/e2e/playwright-report/
# playwright resolves these relative to the repo root, not the config dir
/test-results/
/playwright-report/
