node_modules
.env
.env.local
dist
build
*.log
.DS_Store
coverage

# npm workspaces use a single root lockfile; nested per-app locks are stray
# artifacts from running `npm install` inside a workspace and must not be tracked.
apps/*/package-lock.json

# Playwright e2e output
/e2e/test-results/
/e2e/playwright-report/
# playwright resolves these relative to the repo root, not the config dir
/test-results/
/playwright-report/
