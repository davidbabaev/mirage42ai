# Copy to .env and fill in. NEVER commit the real .env (see CLAUDE.md guardrail 4).
#
# Every var the app actually reads is listed here. Anything marked OPTIONAL can be
# left blank: the related feature disables itself rather than crashing.

# ---- Database -------------------------------------------------------------
# Local docker compose provides its own mongo, so this default just works.
# For Atlas, paste the SRV string here instead.
DB_CONNECTION_STRING=mongodb://localhost:27017/mirage42

# ---- API ------------------------------------------------------------------
PORT=8181
NODE_ENV=development

# Must be a long random string. Rotating it invalidates every existing session.
JWT_SECRET=

# Where the browser app is served from. Used for CORS and OAuth redirects.
CLIENT_URL=http://localhost:5173
# Comma-separated. Requests from any other origin are refused.
ALLOWED_ORIGINS=http://localhost:5173
# The API's own public URL (OAuth callbacks come back here).
SERVER_URL=http://localhost:8181

# How long an access token lives. Keep it SHORT — the client refreshes silently.
# The e2e suite deliberately sets this to 8s to make "a long session" testable.
ACCESS_TOKEN_TTL=15m
# Refresh-token lifetime in ms. Default is 7 days.
REFRESH_TOKEN_TTL_MS=604800000

# ---- Web (Vite) -----------------------------------------------------------
# NOTE: baked into the bundle at BUILD time, not read at runtime.
VITE_API_URL=http://localhost:8181

# ---- OPTIONAL: Google OAuth ----------------------------------------------
# Blank = the "Sign in with Google" button is disabled.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- OPTIONAL: Cloudinary (image/video uploads) --------------------------
# Blank = uploads are disabled.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ---- OPTIONAL: Sentry (error monitoring) ---------------------------------
# Blank = Sentry is a no-op. Set it in staging/production only.
SENTRY_DSN=
VITE_SENTRY_DSN=
# Distinguishes staging from production in the Sentry UI.
SENTRY_ENVIRONMENT=development

# ---- Agent runtime (apps/agents) ------------------------------------------
# The kill-switch. Blank/absent/anything unrecognised = agents do NOT run.
# Only '1', 'true', 'yes' or 'on' start the worker — a runtime that posts and
# messages as if it were a person should never start by accident.
AGENTS_ENABLED=false

# ---- OPTIONAL: preview deploys -------------------------------------------
# Regex of extra allowed origins (e.g. Vercel preview URLs).
PREVIEW_ORIGIN_REGEX=
