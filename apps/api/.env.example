# 'production' enables prod behavior: Secure;SameSite=None refresh cookie, HSTS,
# and required Cloudinary config. Leave unset (or 'development') for local dev.
NODE_ENV=development
PORT=8181
DB_CONNECTION_STRING=your_mongodb_connection_string_here
JWT_SECRET=your_secret_here
# Comma-separated list of front-end origins allowed by CORS (HTTP + socket.io).
# The local Vite origin is added automatically outside production, so this can
# be left empty in dev. In production set it to the deployed web URL(s).
ALLOWED_ORIGINS=
# Optional regex (scoped to YOUR project) allowing per-deploy preview origins
# whose hostname changes every deploy and so can't be listed statically above.
# Example for Vercel previews of this project:
#   PREVIEW_ORIGIN_REGEX=^https://mirage42[a-z0-9-]*\.vercel\.app$
# Keep it scoped to your project prefix — do NOT use a blanket .vercel.app$,
# which would allow any site on that platform to make credentialed requests.
PREVIEW_ORIGIN_REGEX=
GOOGLE_CLIENT_ID=your_client_id_here
GOOGLE_CLIENT_SECRET=your_client_secret_here
# Public URL of the front-end. Used to build OAuth redirect and share deep-link
# URLs. Required in production (boot fails if unset); falls back to the local
# Vite origin only in dev/test.
CLIENT_URL=http://localhost:5173
SERVER_URL=http://localhost:8181
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
